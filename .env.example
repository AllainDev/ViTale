# ============================================================
# ViTale Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control!
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string (supports Npgsql format)
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=vitale_db;Username=postgres;Password=your_strong_password;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=20

# ── AUTHENTICATION ───────────────────────────────────────────
# JWT signing secret (must be at least 32 chars of cryptographically secure random data)
JWT_SECRET=CHANGE_ME_TO_A_64_CHARACTER_CRYPTOGRAPHICALLY_SECURE_RANDOM_STRING

# Cookie configuration
COOKIE_DOMAIN=.vitale.vn
# For local development use: COOKIE_DOMAIN=localhost

# ── AI SERVICES ──────────────────────────────────────────────
# Groq Cloud API key (for LLM chat + summarization)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── TEXT-TO-SPEECH ───────────────────────────────────────────
# Azure Cognitive Services TTS
AZURE_TTS_KEY=your_azure_cognitive_services_key
AZURE_TTS_REGION=southeastasia
# Voices: vi-VN-HoaiMyNeural (Vietnamese), en-US-JennyNeural (English)

# ── OAUTH PROVIDERS ──────────────────────────────────────────
# Apple Sign-In (from Apple Developer Console)
OAUTH_APPLE_CLIENT_ID=com.vitale.app
OAUTH_APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID

# Google Identity Services (from Google Cloud Console)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook App (from Facebook Developers)
OAUTH_FACEBOOK_APP_ID=your_facebook_app_id
OAUTH_FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── EMAIL / SMTP ─────────────────────────────────────────────
# SMTP configuration for sending emails (verification, password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=blablovcl@gmail.com
SMTP_PASSWORD=qtroxjwmifrxshwb
SMTP_FROM_EMAIL=blablovcl@gmail.com
SMTP_FROM_NAME=ViTale
# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# ── CLOUDFLARE ───────────────────────────────────────────────
# Cloudflare R2 Object Storage (for TTS audio files, 7-day TTL)
CLOUDFLARE_R2_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_R2_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_R2_BUCKET_ASSETS=vitale-assets
CLOUDFLARE_R2_BUCKET_BACKUPS=vitale-backups
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://r2.vitale.vn

# Cloudflare API (for asset deployment via GitHub Actions)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://app.vitale.vn,http://localhost:3000

# ── LOGGING ──────────────────────────────────────────────────
# Log level: Trace, Debug, Information, Warning, Error, Critical
LOG_LEVEL=Information

# ── MONITORING / ALERTING ────────────────────────────────────
# Email for operational alerts (backup failure, uptime alerts)
ALERT_EMAIL=admin@vitale.vn

# ── VPS / DEPLOYMENT ─────────────────────────────────────────
# Used by GitHub Actions deploy workflow
VPS_HOST=your.vps.ip.address
# VPS_SSH_KEY is stored as GitHub secret, not here

# ── ADMIN ────────────────────────────────────────────────────
# Simple API key for admin-only endpoints (QR generation, partner management)
ADMIN_API_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_KEY

# ── NEXT.JS FRONTEND (public env vars) ───────────────────────
NEXT_PUBLIC_API_URL=https://api.vitale.vn
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_APPLE_CLIENT_ID=com.vitale.app
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token
